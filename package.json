{
    "name": "sahidawa-india",
    "version": "1.0.0",
    "private": true,
    "description": "India's First Open-Source Citizen Medicine Verifier & Rural Health Bridge",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "npm run test --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "format": "npm run format --workspaces --if-present",
        "test:a11y:voice": "npm run test:a11y:voice -w web",
        "prepare": "npx --yes husky || true",
        "check:migrations": "node scripts/check-migrations.js"
    },
    "keywords": [
        "medicine",
        "verification",
        "health",
        "gssoc",
        "cdsco"
    ],
    "author": "",
    "license": "MIT",
    "packageManager": "npm@10.9.7",
    "dependencies": {
        "@supabase/supabase-js": "^2.108.2",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.2.0",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.8",
        "morgan": "^1.10.1",
        "react-intersection-observer": "^10.0.3",
        "redis": "^6.0.1",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@parcel/watcher": "^2.5.6",
        "@types/node": "^26.0.0",
        "@types/winston": "^2.4.4",
        "eslint": "^10.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.8.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "turbo": "^2.10.0"
    },
    "overrides": {
        "@zxing/library": "0.23.0",
        "postcss": "^8.5.10",
        "form-data": "^4.0.6",
        "protobufjs": "^7.6.3",
        "js-yaml": "^4.1.2",
        "node-cron": {
            "uuid": "^11.1.1"
        }
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,md,json}": "prettier --write"
    }
}
